    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.44.7",
    "hono": "^4.12.5",
    "hono-rate-limiter": "^0.5.3",
    "jose": "^6.2.0",
    "nodemailer": "^8.0.1",
    "otpauth": "^9.5.0",
    "postgres": "^3.4.8",
    "qrcode": "^1.5.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "drizzle-kit": "^0.31.9",
