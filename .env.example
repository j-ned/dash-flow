# Server
PORT=3000
NODE_ENV=production

# Database (required)
DATABASE_URL=postgresql://user:password@host:5432/dashflow_db

# Auth (required — min 32 chars)
JWT_SECRET=change-me-to-a-random-64-char-string

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=user
SMTP_PASS=password
SMTP_FROM="DashFlow <noreply@example.com>"

# S3 (Garage)
S3_ENDPOINT=https://s3.example.com
S3_REGION=garage
S3_BUCKET_AVATAR=dashflow-avatars
S3_BUCKET_ORDO=dashflow-ordonnances
S3_BUCKET_SALAIRE=dashflow-salaire
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key

# OAuth (Google)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Frontend
APP_URL=https://your-domain.com
CORS_ORIGIN=https://your-domain.com
